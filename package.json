{
  "name": "imchong-github-io",
  "private": true,
  "version": "1.0.0",
  "description": "Chong Liu personal academic homepage",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint:html": "html-validate \"index.html\" \"experience/**/*.html\" \"family/**/*.html\"",
    "check": "npm run format:check && npm run lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "html-validate": "^9.7.1",
    "prettier": "^3.5.3",
    "stylelint": "^16.18.0",
    "stylelint-config-standard": "^38.0.0"
  }
}
